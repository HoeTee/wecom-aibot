# LLM settings required by backend_app.py / base_agent.py
LLM_API_KEY=your_llm_api_key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
TEMPERATURE=0
TOP_P=0.01
SEED=42

# Optional agent limits
MAX_TOOL_CALLS=10
MAX_CONTEXT_TOKENS=100000
MAX_RESULT_TOKENS=5000

# Optional local llamaindex_rag MCP server settings
EMBED_API_KEY=your_embed_api_key
EMBED_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBED_MODEL=text-embedding-v4
RERANK_API_KEY=your_rerank_api_key
RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
RERANK_MODEL=qwen3-rerank

# WeCom gateway settings required by long_connection.ts
WECOM_BOT_ID=your_wecom_bot_id
WECOM_BOT_SECRET=your_wecom_bot_secret
BACKEND_BASE_URL=http://127.0.0.1:5000

# Optional MCP host config used by backend_app.py and mcp_test.py
MCP_SERVERS_CONFIG=config/mcp_servers.json
# Legacy fallback for a single MCP server. Prefer MCP_SERVERS_CONFIG for new setups.
MCP_SERVER_URL=
