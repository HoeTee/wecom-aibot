# LLM settings required by backend_app.py / base_agent.py
LLM_API_KEY=your_llm_api_key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_NAME=qwen-plus
TEMPERATURE=0
TOP_P=0.01
SEED=42

# Optional agent limits
MAX_TOOL_CALLS=10
MAX_CONTEXT_TOKENS=100000
MAX_RESULT_TOKENS=5000

# WeCom gateway settings required by long_connection.ts
WECOM_BOT_ID=your_wecom_bot_id
WECOM_BOT_SECRET=your_wecom_bot_secret
BACKEND_BASE_URL=http://127.0.0.1:5000

# Optional MCP endpoint used by backend_app.py and mcp_test.py
MCP_SERVER_URL=
